# Backend environment variables
# Copy this file to .env and fill in the values

# JWT secret — use a long random string in production
SECRET_KEY=change-me-to-a-long-random-string

# Database URL (default: SQLite file for Render free tier)
DATABASE_URL=sqlite:///./portfolio.db

# Frontend URL for CORS (your Vercel deployment URL)
FRONTEND_URL=https://your-frontend.vercel.app

# Email notification settings (optional — leave blank to skip email alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password

# Where to send new-message notifications
NOTIFY_EMAIL=harshar9177@gmail.com
NOTIFY_PHONE=8722831505
